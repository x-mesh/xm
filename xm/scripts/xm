#!/usr/bin/env bash
# xm — umbrella CLI for x-mesh toolkit
# Dispatches to plugin-cache lib files installed by Claude Code.
#
# Install: curl -fsSL .../xm/scripts/install.sh | bash
# Update : xm update  (or re-run installer)

set -euo pipefail

CMD="${1:-help}"
[ $# -gt 0 ] && shift

# --- Self-register hook ---
# When invoked from a directory containing .xm/, ensure the project is in the
# registry. Silent on already-registered. Skipped for management commands so
# `xm project import` / `gc` / `--help` don't trigger themselves.
self_register() {
  # Best-effort only — must always return 0 so `set -e` does not kill the
  # whole script when called from a directory without .xm/.git.
  case "$CMD" in
    help|--help|-h|version|--version|-v|which|init|project) return 0 ;;
  esac
  [ -d ".xm" ] || [ -f ".git" ] || [ -d ".git" ] || return 0
  local libPath
  libPath="$(plugin_lib xm lib 2>/dev/null)" || return 0
  [ -f "$libPath/x-projects-cli.mjs" ] || return 0
  node "$libPath/x-projects-cli.mjs" register --quiet >/dev/null 2>&1 || true
  return 0
}

# --- Resolve lib root ---
# Priority: $XM_LIB env (or legacy $X_KIT_LIB) > local repo (cwd has x-build/lib + xm/lib) > plugin cache
resolve_lib() {
  local override="${XM_LIB:-${X_KIT_LIB:-}}"
  if [ -n "$override" ] && [ -d "$override" ]; then
    echo "$override"; return
  fi
  if [ -d "x-build/lib" ] && [ -d "xm/lib" ]; then
    echo "$PWD"; return
  fi
  # Marketplace cache (post-rename): ~/.claude/plugins/cache/xm
  local cache="$HOME/.claude/plugins/cache/xm"
  if [ -d "$cache" ]; then
    echo "$cache"; return
  fi
  # Legacy cache path (pre-rename) — kept for in-flight upgrades
  local legacy="$HOME/.claude/plugins/cache/x-kit"
  if [ -d "$legacy" ]; then
    echo "$legacy"; return
  fi
  echo ""
}

LIB="$(resolve_lib)"
if [ -z "$LIB" ]; then
  echo "xm: no lib found. Install Claude plugins or set XM_LIB." >&2
  exit 1
fi

# Resolve a plugin's lib directory. Tries both the long source-dir name
# (`x-build` in local repo) and the short marketplace plugin name (`build`
# in cache). Callers pass the short name and we probe both forms.
#
# Resolution order:
#   1. Local repo: $LIB/x-<plugin>/<sub>     (e.g. x-build/lib in source tree)
#   2. Local repo: $LIB/<plugin>/<sub>       (e.g. xm/lib — bundle source)
#   3. Cache: $LIB/<plugin>/<version>/<sub>  (marketplace layout, short name)
#   4. Bundled fallback inside xm meta plugin
plugin_lib() {
  local plugin="$1" sub="${2:-lib}"
  local long="x-$plugin"

  # 1. Local repo with x- prefix (source tree for most plugins)
  if [ -d "$LIB/$long/$sub" ]; then echo "$LIB/$long/$sub"; return 0; fi
  # 2. Local repo with short name (xm bundle source)
  if [ -d "$LIB/$plugin/$sub" ]; then echo "$LIB/$plugin/$sub"; return 0; fi
  # 3. Cache: short name, versioned
  local path
  path="$(ls -td "$LIB/$plugin"/*/"$sub" 2>/dev/null | head -1 || true)"
  if [ -n "$path" ]; then echo "$path"; return 0; fi
  # 4. Bundled fallback: sub-plugins ship inside xm bundle
  if [ "$plugin" != "xm" ]; then
    # Local repo: xm/<sub>
    if [ -d "$LIB/xm/$sub" ]; then echo "$LIB/xm/$sub"; return 0; fi
    # Cache: xm/<version>/<sub>
    path="$(ls -td "$LIB/xm"/*/"$sub" 2>/dev/null | head -1 || true)"
    [ -n "$path" ] && echo "$path"
  fi
}

self_register

# --- Terminal instrumentation (best-effort dispatcher ledger) ---
# Record a `dispatcher` activity trace after the real command finishes, on every
# exit path (natural end, explicit `exit N`, or `set -e` abort) WITHOUT changing
# its exit code. Only mutating commands are recorded — read-only/meta commands
# and `dashboard` (which daemonizes) are excluded, so the ~50-100ms node spawn is
# paid only where an activity trace is actually useful (RV cost concern).
#
# Why a trap and not code after `esac`: `set -e` makes a non-zero `node ...`
# abort the script AT the dispatch line, so post-`esac` code would never run on
# the very failures worth recording. The EXIT trap fires on all paths.
#
# Exit-code fidelity: the trap captures $? first, then `set +e` — otherwise a
# failing best-effort write under `set -e` aborts the trap before `exit $code`
# runs, letting the trap's last command status leak out as the script's exit code
# (verified). Capturing $CMD/$1 now, before any case-local `shift` consumes them.
XM_TRACE_CMD="$CMD"
XM_TRACE_SUB="${1:-}"
XM_TRACE_SUB2="${2:-}"
_xm_trace_record() {
  local code=$?
  set +e
  # Excluded top-level commands: help/version/which/doctor/init/update are meta,
  # trace/last/status are the ledger's own read views, dashboard daemonizes.
  case "$XM_TRACE_CMD" in
    help|--help|-h|""|version|--version|-v|which|doctor|init|update|dashboard|dash|trace|last|status)
      exit "$code" ;;
  esac
  # Excluded read-only sub-ops. The read verb is $1 for flat verbs (`config get`)
  # but $2 for noun-verb commands (`build tasks list`, `build task show`), so both
  # positions are checked. Trade-off: a write whose $2 *value* is literally
  # list/get/show is wrongly skipped — negligible in this CLI's grammar (writes
  # take keys/ids/text there), and a rare miss is fine for a best-effort ledger.
  case "$XM_TRACE_SUB" in
    list|get|show) exit "$code" ;;
  esac
  case "$XM_TRACE_SUB2" in
    list|get|show) exit "$code" ;;
  esac
  local libp
  libp="$(plugin_lib trace 2>/dev/null)"
  if [ -n "$libp" ] && [ -f "$libp/x-trace-cli.mjs" ]; then
    local status="error"
    [ "$code" -eq 0 ] && status="ok"
    local note="$XM_TRACE_CMD"
    [ -n "$XM_TRACE_SUB" ] && note="$XM_TRACE_CMD $XM_TRACE_SUB"
    if [ "${XM_TRACE_DEBUG:-0}" = "1" ]; then
      node "$libp/x-trace-cli.mjs" record dispatcher --note "$note" --status "$status" >&2 || true
    else
      node "$libp/x-trace-cli.mjs" record dispatcher --note "$note" --status "$status" >/dev/null 2>&1 || true
    fi
  fi
  exit "$code"
}
trap _xm_trace_record EXIT

# --- Subcommand dispatch ---
case "$CMD" in
  dashboard|dash)
    LIB_PATH="$(plugin_lib dashboard)"
    if [ -z "$LIB_PATH" ] || [ ! -f "$LIB_PATH/x-dashboard-server.mjs" ]; then
      echo "xm dashboard: x-dashboard-server.mjs not found under $LIB" >&2
      echo "  Install bundle: /plugin install xm@xm" >&2
      echo "  Or standalone: /plugin install dashboard@xm" >&2
      exit 1
    fi
    # Subcommand is one of start|stop|status|open; anything starting with `-`
    # (e.g. --scan, --port) is treated as a flag to the implicit `start`.
    SUB="${1:-start}"
    case "$SUB" in
      start|stop|status|open|restart) shift || true ;;
      -*) SUB="start" ;;
      *)  echo "xm dashboard: start|stop|status|open|restart [--scan DIR] [--port N]" >&2; exit 1 ;;
    esac
    # restart = stop the running server, then fall through to the start path so
    # a relaunch picks up new server code / a different served bundle (the cure
    # for a long-lived server pinning a stale public/ — see RV-1).
    if [ "$SUB" = "restart" ]; then
      # Forward flags (e.g. --port) to --stop too, so a non-default-port server is
      # targeted correctly even when its PID file is missing (stop then falls back to
      # probing the right port instead of the default). Start reuses "$@" below.
      bun "$LIB_PATH/x-dashboard-server.mjs" --stop "$@" || true
      SUB="start"
    fi
    case "$SUB" in
      start)
        # Scan root precedence: --scan flag > $XM_DASHBOARD_SCAN > ~/.xm/config.json scan_roots > single-project mode
        SCAN_ARGS=()
        SCAN_SOURCE=""
        if [[ "$*" != *"--scan"* ]]; then
          if [ -n "${XM_DASHBOARD_SCAN:-}" ]; then
            SCAN_ARGS=(--scan "$XM_DASHBOARD_SCAN")
            SCAN_SOURCE="$XM_DASHBOARD_SCAN"
          elif [ -f "$HOME/.xm/config.json" ]; then
            ROOT="$(node -e 'try{const j=JSON.parse(require("fs").readFileSync(process.env.HOME+"/.xm/config.json","utf8"));if(Array.isArray(j.scan_roots)&&j.scan_roots.length)process.stdout.write(j.scan_roots[0].replace(/^~/,process.env.HOME))}catch{}' 2>/dev/null)"
            if [ -n "$ROOT" ]; then
              SCAN_ARGS=(--scan "$ROOT")
              SCAN_SOURCE="$ROOT (from ~/.xm/config.json)"
            fi
          fi
        fi
        LOG="${TMPDIR:-/tmp}/x-dashboard.log"
        nohup bun "$LIB_PATH/x-dashboard-server.mjs" --session "${SCAN_ARGS[@]}" "$@" >> "$LOG" 2>&1 & disown
        PID=$!
        sleep 1
        if ! kill -0 "$PID" 2>/dev/null; then
          echo "xm dashboard: failed to start — see $LOG" >&2
          tail -20 "$LOG" >&2 || true
          exit 1
        fi
        echo "xm dashboard: started at http://127.0.0.1:19841${SCAN_SOURCE:+ (scan: $SCAN_SOURCE)}"
        ;;
      stop)   bun "$LIB_PATH/x-dashboard-server.mjs" --stop ;;
      status) curl -s http://127.0.0.1:19841/api/health 2>/dev/null || echo '{"status":"not_running"}' ;;
      open)   open http://127.0.0.1:19841 ;;
    esac
    ;;

  handoff)
    LIB_PATH="$(plugin_lib build)"
    node "$LIB_PATH/x-build-cli.mjs" handoff --full "$@"
    ;;

  handon)
    LIB_PATH="$(plugin_lib build)"
    node "$LIB_PATH/x-build-cli.mjs" handon "$@"
    ;;

  memory|mem)
    LIB_PATH="$(plugin_lib memory)"
    node "$LIB_PATH/x-memory-cli.mjs" "$@"
    ;;

  recall)
    LIB_PATH="$(plugin_lib recall)"
    node "$LIB_PATH/x-recall-cli.mjs" "$@"
    ;;

  panel)
    LIB_PATH="$(plugin_lib panel)"
    node "$LIB_PATH/x-panel-cli.mjs" "$@"
    ;;

  build)
    LIB_PATH="$(plugin_lib build)"
    node "$LIB_PATH/x-build-cli.mjs" "$@"
    ;;

  config)
    LIB_PATH="$(plugin_lib build)"
    if [ -z "$LIB_PATH" ] || [ ! -f "$LIB_PATH/x-config-cli.mjs" ]; then
      echo "xm config: x-config-cli.mjs not found under $LIB" >&2
      echo "  Update xm: xm update" >&2
      exit 1
    fi
    node "$LIB_PATH/x-config-cli.mjs" "$@"
    ;;

  trace)
    LIB_PATH="$(plugin_lib trace)"
    if [ -z "$LIB_PATH" ] || [ ! -f "$LIB_PATH/x-trace-cli.mjs" ]; then
      echo "xm trace: x-trace-cli.mjs not found under $LIB" >&2
      echo "  Update xm: xm update" >&2
      exit 1
    fi
    node "$LIB_PATH/x-trace-cli.mjs" "$@"
    ;;

  # Shortcuts for the two most-used read-only trace views. `xm last` == `xm trace
  # last`; `xm status` == `xm trace status`. No top-level `last`/`status` case
  # exists elsewhere (dashboard's `status` is a nested sub-case), so no conflict.
  last)
    LIB_PATH="$(plugin_lib trace)"
    if [ -z "$LIB_PATH" ] || [ ! -f "$LIB_PATH/x-trace-cli.mjs" ]; then
      echo "xm last: x-trace-cli.mjs not found under $LIB" >&2
      echo "  Update xm: xm update" >&2
      exit 1
    fi
    node "$LIB_PATH/x-trace-cli.mjs" last "$@"
    ;;

  status)
    LIB_PATH="$(plugin_lib trace)"
    if [ -z "$LIB_PATH" ] || [ ! -f "$LIB_PATH/x-trace-cli.mjs" ]; then
      echo "xm status: x-trace-cli.mjs not found under $LIB" >&2
      echo "  Update xm: xm update" >&2
      exit 1
    fi
    node "$LIB_PATH/x-trace-cli.mjs" status "$@"
    ;;

  sync)
    LIB_PATH="$(plugin_lib sync)"
    node "$LIB_PATH/x-sync/sync-${1:-config}.mjs" "${@:2}"
    ;;

  project|projects)
    LIB_PATH="$(plugin_lib xm lib)"
    if [ -z "$LIB_PATH" ] || [ ! -f "$LIB_PATH/x-projects-cli.mjs" ]; then
      echo "xm project: x-projects-cli.mjs not found under $LIB" >&2
      exit 1
    fi
    node "$LIB_PATH/x-projects-cli.mjs" "$@"
    ;;

  init)
    # Resolve setup-global.mjs: local repo > plugin cache
    SETUP=""
    if [ -f "$LIB/xm/scripts/setup-global.mjs" ]; then
      SETUP="$LIB/xm/scripts/setup-global.mjs"
    else
      SETUP="$(ls -td "$LIB/xm"/*/scripts/setup-global.mjs 2>/dev/null | head -1)"
    fi
    if [ -z "$SETUP" ] || [ ! -f "$SETUP" ]; then
      echo "xm init: setup-global.mjs not found under $LIB" >&2
      exit 1
    fi
    node "$SETUP" "$@"
    ;;

  solver)
    LIB_PATH="$(plugin_lib solver)"
    node "$LIB_PATH/x-solver-cli.mjs" "$@"
    ;;

  score)
    LIB_PATH="$(plugin_lib xm lib)"
    if [ -z "$LIB_PATH" ] || [ ! -f "$LIB_PATH/x-score-cli.mjs" ]; then
      echo "xm score: x-score-cli.mjs not found under $LIB" >&2
      echo "  Update xm: xm update" >&2
      exit 1
    fi
    node "$LIB_PATH/x-score-cli.mjs" "$@"
    ;;

  version|--version|-v)
    # Report the ACTIVE lib's version + provenance. During development the
    # local source (XM_LIB / source-repo cwd) and the marketplace cache
    # diverge — `xm which` may pick one while the user expects the other, so
    # version must name WHICH lib answered.
    _vread() {
      [ -f "$1" ] || { echo ""; return; }
      grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' "$1" | head -1 \
        | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/'
    }
    if [ -f "$LIB/xm/.claude-plugin/plugin.json" ]; then
      SRC="local source: $LIB"
      [ -n "${XM_LIB:-${X_KIT_LIB:-}}" ] && SRC="local source via XM_LIB: $LIB"
      echo "xm $(_vread "$LIB/xm/.claude-plugin/plugin.json") ($SRC)"
    else
      # Marketplace cache: pick the HIGHEST version dir. Plain `ls | head -1`
      # is alphabetical — it ranked 2.4.35 above 2.7.2 and printed a version
      # that was long gone.
      PJ="$(ls -d "$LIB/xm"/*/.claude-plugin/plugin.json 2>/dev/null | sort -V | tail -1)"
      if [ -n "$PJ" ]; then
        echo "xm $(_vread "$PJ") (marketplace cache)"
      else
        echo "xm unknown (no plugin.json under $LIB/xm)"
      fi
    fi
    ;;

  doctor)
    # Health check: local install, remote latest, config drift.
    # Flags: --fetch|-f (force remote fetch even if offline hint present)
    REPO_URL="${XM_REPO_URL:-https://raw.githubusercontent.com/x-mesh/xm/main}"

    # Helper: extract "version" from a plugin.json-ish JSON
    _read_version() {
      local path="$1"
      [ -f "$path" ] || { echo ""; return; }
      grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' "$path" | head -1 \
        | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/'
    }

    # Local version — installed_plugins.json is authoritative; fall back to cache scan
    LOCAL_VERSION=""
    LOCAL_SRC=""
    if [ -f "$HOME/.claude/plugins/installed_plugins.json" ] && command -v node >/dev/null 2>&1; then
      LOCAL_VERSION="$(node -e '
        try {
          const fs = require("fs");
          const d = JSON.parse(fs.readFileSync(process.env.HOME + "/.claude/plugins/installed_plugins.json", "utf8"));
          const xm = (d.plugins || {})["xm@xm"];
          const entry = Array.isArray(xm) ? xm[0] : xm;
          if (entry && entry.version) process.stdout.write(entry.version);
        } catch {}
      ' 2>/dev/null)"
      [ -n "$LOCAL_VERSION" ] && LOCAL_SRC="installed_plugins.json"
    fi
    if [ -z "$LOCAL_VERSION" ]; then
      if [ -f "$LIB/xm/.claude-plugin/plugin.json" ]; then
        LOCAL_VERSION="$(_read_version "$LIB/xm/.claude-plugin/plugin.json")"
        LOCAL_SRC="$LIB/xm/.claude-plugin/plugin.json"
      else
        _cached_pj="$(ls -td "$LIB/xm"/*/.claude-plugin/plugin.json 2>/dev/null | head -1)"
        if [ -n "$_cached_pj" ]; then
          LOCAL_VERSION="$(_read_version "$_cached_pj")"
          LOCAL_SRC="$_cached_pj"
        fi
      fi
    fi

    # Remote version — parse marketplace.json, find the "xm" plugin entry
    REMOTE_VERSION=""
    if command -v curl >/dev/null 2>&1; then
      REMOTE_JSON="$(curl -fsSL --max-time 5 "$REPO_URL/.claude-plugin/marketplace.json" 2>/dev/null || echo "")"
      if [ -n "$REMOTE_JSON" ] && command -v node >/dev/null 2>&1; then
        REMOTE_VERSION="$(printf '%s' "$REMOTE_JSON" | node -e '
          let s="";process.stdin.on("data",c=>s+=c).on("end",()=>{
            try{const j=JSON.parse(s);
              const xm=(j.plugins||[]).find(p=>p.name==="xm");
              if(xm) process.stdout.write(xm.version||"");
            }catch{}
          })' 2>/dev/null)"
      fi
    fi

    # ── Render ────────────────────────────────────────────────────
    echo "xm — health check"
    echo ""
    echo "## Installation"
    if [ -n "$LOCAL_VERSION" ]; then
      echo "  ✅ local version     $LOCAL_VERSION"
      echo "     source            $LOCAL_SRC"
    else
      echo "  ❌ local version     unknown (no plugin.json in $LIB/xm)"
    fi
    if [ -x "$HOME/.local/bin/xm" ]; then
      echo "  ✅ CLI binary        $HOME/.local/bin/xm"
    else
      echo "  ⚠️  CLI binary       not in ~/.local/bin/xm"
    fi
    if command -v bun >/dev/null 2>&1; then
      echo "  ✅ bun               $(bun --version 2>/dev/null)"
    else
      echo "  ⚠️  bun              not installed (dashboard needs it)"
    fi

    echo ""
    echo "## Hooks (~/.claude/)"
    # File presence
    if [ -f "$HOME/.claude/hooks/xm-trace-session.mjs" ]; then
      echo "  ✅ xm-trace-session.mjs (file present)"
    else
      echo "  ❌ xm-trace-session.mjs missing — run: xm init"
    fi
    # Legacy file still around?
    if [ -f "$HOME/.claude/hooks/x-kit-trace-session.mjs" ]; then
      echo "  ⚠️  legacy x-kit-trace-session.mjs still present — xm init will remove"
    fi
    # Settings.json registration
    if [ -f "$HOME/.claude/settings.json" ] && command -v node >/dev/null 2>&1; then
      node -e '
        const fs=require("fs"), path=require("path");
        const s=JSON.parse(fs.readFileSync(path.join(process.env.HOME,".claude/settings.json"),"utf8"));
        const all=Object.entries(s.hooks||{});
        const phases=["PreToolUse","PostToolUse"];
        for (const phase of phases) {
          const entries=(s.hooks||{})[phase]||[];
          let xm=null, legacy=null;
          for (const e of entries) {
            if (!Array.isArray(e?.hooks)) continue;
            for (const h of e.hooks) {
              const c=h?.command||"";
              if (/xm-trace-session\.mjs/.test(c)) xm=c;
              else if (/x-kit-trace-session\.mjs/.test(c)) legacy=c;
            }
          }
          if (xm) console.log(`  ✅ settings.json[${phase}] Skill hook → xm-trace-session.mjs`);
          else console.log(`  ⚠️  settings.json[${phase}] no xm Skill hook (run: xm init)`);
          if (legacy) console.log(`  ⚠️  settings.json[${phase}] legacy x-kit-trace-session.mjs still wired`);
        }
      ' 2>/dev/null || echo "  ⚠️  cannot parse ~/.claude/settings.json"
    else
      echo "  ⚠️  ~/.claude/settings.json not found"
    fi

    echo ""
    echo "## Remote (github.com/x-mesh/xm)"
    if [ -n "$REMOTE_VERSION" ]; then
      echo "  ✅ latest version    $REMOTE_VERSION"
      if [ -n "$LOCAL_VERSION" ] && [ "$LOCAL_VERSION" = "$REMOTE_VERSION" ]; then
        echo "  ✅ status            up to date"
      elif [ -n "$LOCAL_VERSION" ]; then
        echo "  ⚠️  status           local ($LOCAL_VERSION) ≠ remote ($REMOTE_VERSION)"
        echo "     update            claude plugin install xm@xm -s user"
      fi
    else
      echo "  ⚠️  latest version   unreachable (offline or $REPO_URL blocked)"
    fi

    echo ""
    echo "## Dashboard"
    if [ -f "$HOME/.xm/run/xdashboard-server.pid" ]; then
      _dash_pid="$(grep -o '"pid"[[:space:]]*:[[:space:]]*[0-9]*' "$HOME/.xm/run/xdashboard-server.pid" 2>/dev/null | grep -o '[0-9]*' | head -1)"
      if [ -n "$_dash_pid" ] && kill -0 "$_dash_pid" 2>/dev/null; then
        echo "  ✅ running           pid $_dash_pid (http://127.0.0.1:19841)"
      else
        echo "  ⚠️  stale PID file   (pid $_dash_pid not alive)"
      fi
    elif command -v lsof >/dev/null 2>&1 && lsof -iTCP:19841 -sTCP:LISTEN >/dev/null 2>&1; then
      _port_pid="$(lsof -nP -iTCP:19841 -sTCP:LISTEN -Fp 2>/dev/null | head -1 | sed 's/^p//')"
      echo "  ⚠️  orphan            port 19841 held by pid $_port_pid (no PID file)"
      echo "     stop              kill $_port_pid"
    else
      echo "  ⏸  not running       (start: xm dashboard start)"
    fi

    echo ""
    echo "## Bundle / release state"
    VERIFY_STATE=""
    if [ -f "$LIB/scripts/verify-release-state.mjs" ]; then
      VERIFY_STATE="$LIB/scripts/verify-release-state.mjs"
    elif [ -f "$LIB/xm/scripts/verify-release-state.mjs" ]; then
      VERIFY_STATE="$LIB/xm/scripts/verify-release-state.mjs"
    fi
    if [ -z "$VERIFY_STATE" ] || [ ! -f "$LIB/package.json" ]; then
      echo "  ⏭  source checks     unavailable (requires source checkout)"
    elif ! command -v node >/dev/null 2>&1; then
      echo "  ⚠️  source checks     node not installed"
    else
      if VERIFY_JSON="$(node "$VERIFY_STATE" --json 2>&1)"; then
        VERIFY_STATUS=0
      else
        VERIFY_STATUS=$?
      fi
      if printf '%s' "$VERIFY_JSON" | node -e '
        let input = "";
        process.stdin.on("data", (chunk) => input += chunk);
        process.stdin.on("end", () => {
          try {
            const data = JSON.parse(input);
            for (const result of data.results || []) {
              const icon = result.ok ? "✅" : "❌";
              const name = String(result.name || "check").padEnd(19);
              const lines = String(result.output || "").split(/\n/).filter(Boolean);
              const summary = lines[lines.length - 1] || "";
              console.log(`  ${icon} ${name} ${summary}`.trimEnd());
            }
          } catch {
            process.exit(2);
          }
        });
      ' 2>/dev/null; then
        if [ "$VERIFY_STATUS" -ne 0 ]; then
          echo "     fix               bun run verify"
        fi
      else
        echo "  ❌ release-state     unable to parse checker output"
        printf '%s\n' "$VERIFY_JSON" | tail -8 | sed 's/^/     /'
      fi
    fi

    echo ""
    echo "## Resolved lib paths"
    for p in xm dashboard build memory trace sync solver; do
      resolved="$(plugin_lib "$p")"
      if [ -n "$resolved" ]; then
        echo "  ✅ $(printf '%-12s' "$p") $resolved"
      else
        echo "  ❌ $(printf '%-12s' "$p") (missing)"
      fi
    done

    echo ""
    echo "## Cross-vendor providers (panel)"
    PANEL_LIB="$(plugin_lib panel)"
    if [ -n "$PANEL_LIB" ] && [ -f "$PANEL_LIB/x-panel-cli.mjs" ]; then
      echo "  ✅ installed         $PANEL_LIB"
      echo "     readiness         xm panel doctor   (install + auth per vendor, no model call)"
      echo "     configure         xm panel setup    ·   models: xm panel models <vendor>"
    else
      echo "  ⏸  not installed     (install: /plugin install panel@xm)"
    fi
    ;;

  update)
    # Update marketplace cache + reinstall plugin + refresh CLI binary.
    # Flags: --force|-f (update even if versions match), --dry-run, --no-cli (skip binary copy)
    FORCE=0; DRY=0; SKIP_CLI=0; NO_PROPAGATE=0
    for a in "$@"; do
      case "$a" in
        --force|-f)      FORCE=1 ;;
        --dry-run)       DRY=1 ;;
        --no-cli)        SKIP_CLI=1 ;;
        --no-propagate)  NO_PROPAGATE=1 ;;
        *) echo "xm update: unknown flag '$a'" >&2; exit 1 ;;
      esac
    done

    REPO_URL="${XM_REPO_URL:-https://raw.githubusercontent.com/x-mesh/xm/main}"

    _read_version() {
      local path="$1"
      [ -f "$path" ] || { echo ""; return; }
      grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' "$path" | head -1 \
        | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/'
    }

    # 1. Current installed version
    # Primary: installed_plugins.json is authoritative (version-exact, not mtime-sorted)
    # Fallback: scan cache directory
    LOCAL_VERSION=""
    if [ -f "$HOME/.claude/plugins/installed_plugins.json" ] && command -v node >/dev/null 2>&1; then
      LOCAL_VERSION="$(node -e '
        try {
          const fs = require("fs");
          const d = JSON.parse(fs.readFileSync(process.env.HOME + "/.claude/plugins/installed_plugins.json", "utf8"));
          const xm = (d.plugins || {})["xm@xm"];
          const entry = Array.isArray(xm) ? xm[0] : xm;
          if (entry && entry.version) process.stdout.write(entry.version);
        } catch {}
      ' 2>/dev/null)"
    fi
    if [ -z "$LOCAL_VERSION" ]; then
      if [ -f "$LIB/xm/.claude-plugin/plugin.json" ]; then
        LOCAL_VERSION="$(_read_version "$LIB/xm/.claude-plugin/plugin.json")"
      else
        _cached_pj="$(ls -td "$LIB/xm"/*/.claude-plugin/plugin.json 2>/dev/null | head -1)"
        [ -n "$_cached_pj" ] && LOCAL_VERSION="$(_read_version "$_cached_pj")"
      fi
    fi

    # 2. Remote latest version
    command -v curl >/dev/null 2>&1 || { echo "xm update: curl required" >&2; exit 1; }
    REMOTE_JSON="$(curl -fsSL --max-time 5 "$REPO_URL/.claude-plugin/marketplace.json" 2>/dev/null || echo "")"
    if [ -z "$REMOTE_JSON" ]; then
      echo "xm update: could not reach $REPO_URL (offline?)" >&2
      exit 1
    fi
    REMOTE_VERSION="$(printf '%s' "$REMOTE_JSON" | node -e '
      let s="";process.stdin.on("data",c=>s+=c).on("end",()=>{
        try{const j=JSON.parse(s);
          const xm=(j.plugins||[]).find(p=>p.name==="xm");
          if(xm) process.stdout.write(xm.version||"");
        }catch{}
      })' 2>/dev/null)"

    if [ -z "$REMOTE_VERSION" ]; then
      echo "xm update: could not parse remote version" >&2
      exit 1
    fi

    echo "Local:  ${LOCAL_VERSION:-unknown}"
    echo "Remote: $REMOTE_VERSION"

    # 3. Decide whether to proceed
    if [ -n "$LOCAL_VERSION" ] && [ "$LOCAL_VERSION" = "$REMOTE_VERSION" ] && [ "$FORCE" = "0" ]; then
      echo "✅ already up to date. Pass --force to reinstall anyway."
      exit 0
    fi

    echo ""
    if [ "$DRY" = "1" ]; then
      echo "🔍 Dry run — would run:"
      echo "   claude plugin marketplace update xm"
      echo "   claude plugin update xm@xm"
      echo "   claude plugin update <each installed @xm sub-plugin>  # panel@xm, build@xm, …"
      [ "$SKIP_CLI" = "0" ] && echo "   cp <cache>/xm/scripts/xm ~/.local/bin/xm"
      [ "$NO_PROPAGATE" = "0" ] && echo "   node <cache>/install-cli.mjs --propagate"
      exit 0
    fi

    # 4. Refresh marketplace metadata, then upgrade plugin
    #    - `marketplace update` is required: without it `plugin update/install`
    #      sees only the stale cached marketplace.json and skips the upgrade.
    #    - `plugin update` (not `install`) is required: `install` is a no-op
    #      when the plugin is already installed at any version.
    if ! command -v claude >/dev/null 2>&1; then
      echo "xm update: 'claude' CLI not on PATH. Install it first." >&2
      exit 1
    fi
    echo "→ claude plugin marketplace update xm"
    claude plugin marketplace update xm 2>&1 | tail -2
    echo "→ claude plugin update xm@xm"
    claude plugin update xm@xm 2>&1 | tail -3
    # If the expected version directory is still missing (update reported "already at latest"
    # but cache was wiped), force a reinstall to materialize the files.
    EXPECTED_CACHE_DIR="$HOME/.claude/plugins/cache/xm/xm/$REMOTE_VERSION"
    if [ ! -d "$EXPECTED_CACHE_DIR" ]; then
      echo "→ cache missing for $REMOTE_VERSION — reinstalling"
      claude plugin install xm@xm 2>&1 | tail -3
    fi

    # 4b. Update every INSTALLED sub-plugin too (panel@xm, build@xm, …). The dispatcher runs each
    #     sub-command from that plugin's OWN cache dir (cache/xm/<plugin>/<version>), NOT the xm meta
    #     bundle, so updating only xm@xm above leaves `xm panel` / `xm build` on stale code. This is
    #     the same loop the /xm:kit update skill runs — the terminal path must match it.
    if command -v node >/dev/null 2>&1; then
      SUBPLUGINS="$(node -e '
        try {
          const fs = require("fs");
          const d = JSON.parse(fs.readFileSync(process.env.HOME + "/.claude/plugins/installed_plugins.json", "utf8"));
          const valid = /^[a-zA-Z0-9@._-]+$/;
          const keys = Object.keys(d.plugins || {}).filter(k => k.endsWith("@xm") && k !== "xm@xm" && valid.test(k));
          process.stdout.write(keys.join(" "));
        } catch {}
      ' 2>/dev/null)"
      if [ -n "$SUBPLUGINS" ]; then
        echo "→ updating sub-plugins: $SUBPLUGINS"
        for p in $SUBPLUGINS; do
          echo "   $p"
          claude plugin update "$p" -s user 2>&1 | grep -iE "updated|latest|error" | tail -1
        done
      fi
    fi

    # 5. Refresh bash CLI binary from the newly-installed cache
    # Use the explicit REMOTE_VERSION path — avoids picking a stale version by mtime.
    if [ "$SKIP_CLI" = "0" ]; then
      NEW_CACHE="$HOME/.claude/plugins/cache/xm/xm/$REMOTE_VERSION/scripts/xm"
      if [ ! -f "$NEW_CACHE" ]; then
        NEW_CACHE="$(ls -td "$HOME/.claude/plugins/cache/xm/xm"/*/scripts/xm 2>/dev/null | head -1)"
      fi
      if [ -n "$NEW_CACHE" ] && [ -f "$NEW_CACHE" ]; then
        BIN_DIR="${XM_BIN_DIR:-$HOME/.local/bin}"
        mkdir -p "$BIN_DIR"
        # Atomic replace: write to temp + rename. A direct `cp` overwrites the
        # currently-executing script's inode in place, causing bash to read
        # garbage from the new bytes at its current offset and emit errors like
        # `line 551: Structured: command not found`. `mv` swaps inodes so the
        # running process keeps reading the original file until exit.
        cp "$NEW_CACHE" "$BIN_DIR/xm.new"
        chmod +x "$BIN_DIR/xm.new"
        mv "$BIN_DIR/xm.new" "$BIN_DIR/xm"
        echo "→ refreshed $BIN_DIR/xm"
      else
        echo "⚠️  CLI binary source not found in cache (skipped)"
      fi
    fi

    # 6. Refresh ~/.claude/commands/xm.md dispatcher + hook file + settings.json
    #    Skill hook entries. Without this step the user has to know to run
    #    `xm init` separately whenever the dispatcher/hook source changes —
    #    a frequent UX regression for new aliases or hook updates.
    NEW_SETUP="$HOME/.claude/plugins/cache/xm/xm/$REMOTE_VERSION/scripts/setup-global.mjs"
    if [ ! -f "$NEW_SETUP" ]; then
      NEW_SETUP="$(ls -td "$HOME/.claude/plugins/cache/xm/xm"/*/scripts/setup-global.mjs 2>/dev/null | head -1)"
    fi
    if [ -n "$NEW_SETUP" ] && [ -f "$NEW_SETUP" ] && command -v node >/dev/null 2>&1; then
      echo "→ refreshing global hooks/dispatcher"
      node "$NEW_SETUP" install 2>&1 | sed 's/^/    /'
    fi

    # 7. Propagate to other installed LLM targets (cursor/codex/kiro/...)
    if [ "$NO_PROPAGATE" = "0" ]; then
      NEW_CLI="$HOME/.claude/plugins/cache/xm/xm/$REMOTE_VERSION/lib/install/install-cli.mjs"
      if [ ! -f "$NEW_CLI" ]; then
        NEW_CLI="$(ls -td "$HOME/.claude/plugins/cache/xm/xm"/*/lib/install/install-cli.mjs 2>/dev/null | head -1)"
      fi
      if [ -n "$NEW_CLI" ] && [ -f "$NEW_CLI" ]; then
        # Snapshot lib + skills to tmpdir to avoid source-race when plugin cache
        # is concurrently rewritten by another marketplace update.
        NEW_CACHE_ROOT="$(dirname "$(dirname "$(dirname "$NEW_CLI")")")"   # .../xm/<version>/
        SNAPSHOT_DIR="$(mktemp -d "${TMPDIR:-/tmp}/xm-propagate-XXXXXX")"
        trap 'rm -rf "$SNAPSHOT_DIR"' EXIT INT TERM
        cp -R "$NEW_CACHE_ROOT/lib" "$SNAPSHOT_DIR/lib" 2>/dev/null
        cp -R "$NEW_CACHE_ROOT/skills" "$SNAPSHOT_DIR/skills" 2>/dev/null
        SNAP_CLI="$SNAPSHOT_DIR/lib/install/install-cli.mjs"
        SNAP_LIB="$SNAPSHOT_DIR/lib"
        SNAP_SKILLS="$SNAPSHOT_DIR/skills"

        if [ -f "$SNAP_CLI" ] && [ -d "$SNAP_LIB" ] && [ -d "$SNAP_SKILLS" ]; then
          echo "→ propagating to other LLM targets"
          PROPAGATE_OUT="$(node "$SNAP_CLI" --propagate --lib-dir "$SNAP_LIB" --skills-dir "$SNAP_SKILLS" 2>&1)"
          PROPAGATE_EXIT=$?
          if [ "$PROPAGATE_EXIT" = "0" ]; then
            SUMMARY="$(printf '%s' "$PROPAGATE_OUT" | node -e '
              let s=""; process.stdin.on("data",c=>s+=c).on("end",()=>{
                try {
                  const j=JSON.parse(s);
                  const sm=j.summary||{};
                  const total=sm.total||0, ok=(sm.success||0)+(sm.migrated||0), skip=sm.skipped||0, fail=sm.failed||0;
                  process.stdout.write(`${ok}/${total} updated, ${skip} skipped${fail?", "+fail+" failed":""}`);
                } catch { process.stdout.write("(parse error)"); }
              })' 2>/dev/null)"
            echo "    $SUMMARY"
          else
            echo "⚠️  propagate exited $PROPAGATE_EXIT"
            echo "$PROPAGATE_OUT" | sed "s/^/    /" | tail -10
          fi
        else
          echo "⚠️  propagate snapshot incomplete — skipping fan-out"
        fi
      fi
    fi

    # 8. Runtime-override notice. `xm update` converges everything it OWNS to
    #    the marketplace state (cache, bin, hooks, overlays) — but resolve_lib
    #    still prefers XM_LIB / a source-repo cwd at runtime. On a dev machine
    #    that means commands keep running LOCAL SOURCE after a successful
    #    update ("update did nothing" confusion) — say so, loudly.
    OVERRIDE_LIB="${XM_LIB:-${X_KIT_LIB:-}}"
    if [ -n "$OVERRIDE_LIB" ] && [ -d "$OVERRIDE_LIB" ]; then
      echo ""
      echo "⚠ XM_LIB override active: $OVERRIDE_LIB"
      echo "   xm commands keep running from that LOCAL SOURCE, not the market install ($REMOTE_VERSION)."
      echo "   → unset XM_LIB (and X_KIT_LIB) to switch to the market install."
    elif [ -d "x-build/lib" ] && [ -d "xm/lib" ]; then
      echo ""
      echo "⚠ current directory is an xm source repo — xm commands run from ./ (local source), not the market install ($REMOTE_VERSION)."
      echo "   → run xm outside this directory for the market install; keep cwd/XM_LIB for release-less local development."
    fi

    echo ""
    echo "✅ Updated to $REMOTE_VERSION"
    echo "💡 Run /reload-plugins in Claude Code to activate new skills"
    # Explicit exit — defense in depth against any future self-rewrite landing
    # before the case block ends.
    exit 0
    ;;

  which)
    echo "lib: $LIB"
    for p in xm dashboard build memory trace sync solver; do
      resolved="$(plugin_lib "$p")"
      printf "  %-12s %s\n" "$p" "${resolved:-(missing)}"
    done
    ;;

  help|--help|-h|"")
    cat <<'EOF'
xm — x-mesh toolkit CLI

Usage: xm <command> [args...]

Commands:
  init [--no-hooks|uninstall|status]  Set up global hooks in ~/.claude/
  project <subcmd>                    Project registry: list|add|remove|import|gc|...
  dashboard start|stop|restart|status|open  Web dashboard server (uses ~/.xm/projects.json)
  handoff [reason]                    Save session state
  handon                              Restore session state
  memory <subcmd>                     Cross-session decision memory
  build <subcmd>                      Phase-based project harness
  config <subcmd>                     Shared toolkit config (--local|--global)
  trace <subcmd>                      Execution traces
  last [tool]                         Shortcut for 'trace last' — last activity per tool
  status [--json]                     Shortcut for 'trace status' — commits since each tool acted
  sync <subcmd>                       Multi-machine .xm sync
                                        push|pull             Sync current project (cwd-based)
                                        push-all|pull-all     Sync all .xm/ projects under --root (default: ~/work)
                                        status                Show config, cwd projectId, last pull/push
                                        setup                 Configure server URL + API key
                                        server start|stop     Local sync server
  solver <subcmd>                     Structured problem solving
  score --parts ... --weights ...     Compute weighted score (shared utility)
  install [--target T] [--global]     Install xm SKILLs into Cursor/Codex/Kiro/Antigravity/OpenCode
  install --list-installed            List all installed manifests as JSON
  install --propagate                 Re-render every installed manifest (best-effort)
  version                             Installed xm version
  doctor                              Health check: local vs remote version, hooks, dashboard
  update [--force|--dry-run|--no-propagate]  Update to latest remote (refreshes plugin + CLI binary, propagates to other targets)
  which                               Show resolved lib paths
  help                                This message

Env:
  XM_LIB       Override lib root (default: plugin cache or cwd)
  X_KIT_LIB    Legacy alias for XM_LIB (deprecated)
  XM_REPO_URL  Override remote fetch base (default: raw.githubusercontent.com/x-mesh/xm/main)

Run 'xm <command> --help' for subcommand details.
EOF
    ;;

  install)
    LIB_PATH="$(plugin_lib xm lib)"
    if [ -z "$LIB_PATH" ] || [ ! -f "$LIB_PATH/install/install-cli.mjs" ]; then
      echo "xm install: install-cli.mjs not found under $LIB" >&2
      echo "  Update xm: xm update" >&2
      exit 1
    fi
    if [ "$#" -eq 0 ] && [ -t 0 ] && [ -t 1 ]; then
      set -- --interactive
    fi
    # Explicitly pass --skills-dir/--lib-dir so install-cli doesn't have to
    # guess the layout. User-supplied "$@" appears after ours; install-cli's
    # last-wins parser lets users override either one.
    PLUGIN_ROOT="$(dirname "$LIB_PATH")"
    SKILLS_DIR="$PLUGIN_ROOT/skills"
    [ -d "$SKILLS_DIR" ] || SKILLS_DIR="$PLUGIN_ROOT/xm/skills"   # source-repo layout
    node "$LIB_PATH/install/install-cli.mjs" \
      --skills-dir "$SKILLS_DIR" \
      --lib-dir "$LIB_PATH" \
      "$@"
    ;;

  *)
    echo "xm: unknown command '$CMD'. Try 'xm help'." >&2
    exit 1
    ;;
esac
