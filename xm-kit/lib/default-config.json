{
  "gates": {
    "research-exit": "human-verify",
    "plan-exit": "human-verify",
    "execute-exit": "auto",
    "verify-exit": "quality",
    "close-exit": "auto"
  },
  "execution": {
    "parallel": true,
    "max_concurrent": 3
  },
  "mode": "developer",
  "agent_level": "medium",
  "agent_profiles": {
    "min":    { "max_agents": 2, "description": "최소 에이전트, 토큰 절약" },
    "medium": { "max_agents": 4, "description": "균형 (기본값)" },
    "max":    { "max_agents": 8, "description": "최대 병렬, 토큰 무제한" }
  },
  "workflow": "interactive",
  "granularity": "standard",
  "model_profile": "balanced",
  "discussion": {
    "default_mode": "interview",
    "max_questions": 6
  },
  "research": {
    "agents": 4,
    "perspectives": ["stack", "features", "architecture", "pitfalls"]
  }
}
