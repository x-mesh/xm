# Runtime data (created per-project, not part of plugin)
.xm/
**/.xm/
.x-build/
.tm-build/
.omc/
.codex/

# x-build runtime (legacy — should no longer appear here)
x-build/lib/projects/
x-build/lib/metrics/

# Node
node_modules/

# Coverage / test artifacts (ephemeral V8 output — regenerated by `bun test`)
coverage/

# Local settings
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db
.gstack/

# Prototypes — LLM outputs (large, noisy); keep scripts/rubrics/golden
prototypes/*/out/
prototypes/*/out-*/
