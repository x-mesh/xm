{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \".codex/xm/hooks/block-marketplace-copy.mjs\""
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \".codex/xm/hooks/trace-session.mjs\" pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \".codex/xm/hooks/trace-session.mjs\" post"
          }
        ]
      }
    ]
  }
}
